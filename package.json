{
  "name": "@moetanorg/moecli",
  "version": "0.1.1",
  "description": "MoeCli - a provider-agnostic coding CLI with OpenAI, Anthropic, Bedrock, Gemini, browser tools, and sub-agents.",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "moecli": "dist/index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.58.0",
    "@aws-sdk/client-bedrock": "^3.901.0",
    "@aws-sdk/client-bedrock-runtime": "^3.901.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.1",
    "openai": "^5.20.1",
    "playwright-core": "^1.55.0",
    "prompts": "^2.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
